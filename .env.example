# ─────────────────────────────────────────────────
# pdd-cli 环境变量配置示例
# 复制为 .env 后按需修改，未设置的变量使用默认值
# ─────────────────────────────────────────────────

# ── 鉴权 ──────────────────────────────────────────

# 商家端登录态文件路径（默认 data/auth-state.json）
# PDD_AUTH_STATE_PATH=

# 消费者端登录态文件路径（默认 data/consumer-auth-state.json）
# goods publish 命令抓取源商品时使用
# PDD_CONSUMER_AUTH_STATE_PATH=

# ── 店铺 ──────────────────────────────────────────

# 默认店铺 ID（省略 --mall 参数时使用）
# PDD_DEFAULT_MALL=

# Mall ID 解析模式：1 = 严格（1-15 位数字），0 = 宽松（最长 64 字符）
# PDD_MALL_ID_STRICT_PARSE=1

# ── 商品发布 ──────────────────────────────────────

# 默认运费模板 ID（省略 --cost-template 参数时使用，否则自动取第一个）
# PDD_PUBLISH_COST_TEMPLATE_ID=

# 第三方类目解析 API 地址（默认 https://api.gj.dangxun.com）
# PDD_CATEGORY_API_BASE=

# ── 限流 ──────────────────────────────────────────

# 全局请求频率（QPS），默认 2
# PDD_RATE_LIMIT_QPS=2

# 突发请求上限，默认 3
# PDD_RATE_LIMIT_BURST=3

# 连续 429 触发全局冷却的阈值次数，默认 3
# PDD_COOLDOWN_THRESHOLD=3

# 全局冷却时长（毫秒），默认 300000（5 分钟）
# PDD_COOLDOWN_MS=300000

# ── 超时 ──────────────────────────────────────────

# 全局命令超时（毫秒），默认无限制
# PDD_TIMEOUT_MS=

# ── 日志 ──────────────────────────────────────────

# 日志级别：trace | debug | info | warn | error | fatal
# PDD_LOG_LEVEL=info

# 日志输出路径（文件路径，不支持 stdout/stderr）
# PDD_LOG_DESTINATION=

# ── Daemon（自动续期）────────────────────────────

# 刷新间隔（毫秒），默认 600000（10 分钟）
# PDD_REFRESH_INTERVAL_MS=600000

# 刷新随机抖动（毫秒），默认 120000（2 分钟）
# PDD_REFRESH_JITTER_MS=120000

# ── 测试 ──────────────────────────────────────────

# 设为 fixture 启用 mock 模式（跳过真实浏览器）
# PDD_TEST_ADAPTER=

# fixture 数据目录（默认 test/fixtures/）
# PDD_TEST_FIXTURE_DIR=

# 设为 1 模拟登录态失效
# PDD_TEST_AUTH_INVALID=

# ── Playwright ────────────────────────────────────

# 浏览器下载镜像（国内加速）
# PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright/
